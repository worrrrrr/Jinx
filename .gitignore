```gitignore
# Dependencies
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.env
.env.local
*.env.*

# Build artifacts
build/
dist/
*.egg-info/

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Coverage reports
.coverage
coverage/
htmlcov/

# Testing
.pytest_cache/
.mypy_cache/

# OS generated files
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
```